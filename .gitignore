# ── Dependencies ────────────────────────────────────────
**/node_modules/

# ── Build / generated artefacts ─────────────────────────
# Plugin test-harness bundles (esbuild output) — only the .ts sources are committed
plugin/test/*.js
# Headless-render visual verification output
plugin/test/out/
# Release staging folder (distribution zips are committed in dist/ and docs/download/)
plugin/release/
# Miscellaneous render temporaries
plugin/test-skia.png
*.tsbuildinfo

# ── Local tool / editor settings ────────────────────────
.claude/
.vscode/
.idea/

# ── OS ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
