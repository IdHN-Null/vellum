{
  "name": "vellum",
  "version": "0.21.0",
  "description": "Vellum — fantasy world map generator & editor for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "esbuild test/unit.ts --bundle --platform=node --outfile=test/unit.js && node test/unit.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "skia-canvas": "^3.0.8",
    "typescript": "^5.6.0"
  }
}
